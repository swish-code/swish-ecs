# =====================================================================
# Swish Compliance (ECS) — environment configuration
# Copy this file to `.env.local` for local dev, or set these vars in your
# host (Railway / Vercel / etc.) for hosted deployments.
#
# Every variable below is read through `src/lib/env.ts` (Zod-validated).
# All variables are optional — the app boots in mock mode with no env vars
# at all — but features turn on as you supply credentials.
# =====================================================================

# ---------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------

# "mock"  → use the local DEV_SESSION_* user below (default).
# "entra" → require Microsoft Entra ID (Azure AD) sign-in via NextAuth.
AUTH_MODE=mock

# Public URL where this app runs (e.g. https://ecs.swish.example.com).
# Required by NextAuth in production for the OAuth callback. Leave empty
# in local dev — NextAuth defaults to http://localhost:3001.
NEXTAUTH_URL=

# Secret used to sign NextAuth JWTs. REQUIRED when AUTH_MODE=entra.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
NEXTAUTH_SECRET=

# Microsoft Entra ID (Azure AD) — required when AUTH_MODE=entra.
# Get these from: Azure portal → App registrations → your app.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Public URL exposed to the browser for the Azure redirect (shown to users
# during the sign-in flow). Optional; usually equals NEXTAUTH_URL + /api/auth/callback/azure-ad.
NEXT_PUBLIC_AZURE_REDIRECT_URI=

# ---------------------------------------------------------------------
# Snowflake (data layer)
# All six are required for the app to talk to Snowflake. With any missing,
# `hasSnowflakeConfig()` returns false and DB-backed pages will fail at
# runtime — the app still boots so you can work on UI without DB access.
# ---------------------------------------------------------------------

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=SWISH_DOCUMENTS
SNOWFLAKE_SCHEMA=ECS_MVP
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# ---------------------------------------------------------------------
# SharePoint / OneDrive (file storage)
# Actual files live in SharePoint; Snowflake stores metadata + URLs.
# ---------------------------------------------------------------------

SHAREPOINT_SITE_URL=
SHAREPOINT_DOCUMENT_LIBRARY=
SHAREPOINT_SITE_ID=

# ---------------------------------------------------------------------
# Email notifications (Outlook via Microsoft Graph)
# Set EMAIL_NOTIFICATIONS_ENABLED=true to actually send mail; otherwise
# the notification service no-ops (useful in dev).
# ---------------------------------------------------------------------

EMAIL_NOTIFICATIONS_ENABLED=false
OUTLOOK_SENDER_EMAIL=

# ---------------------------------------------------------------------
# Local mock session (AUTH_MODE=mock only)
# Defines the fake user the app signs you in as, so you can build UI
# without configuring Azure AD. Ignored when AUTH_MODE=entra.
# ---------------------------------------------------------------------

DEV_SESSION_USER_ID=1
DEV_SESSION_DISPLAY_NAME=Local Business Excellence User
DEV_SESSION_EMAIL=local.user@swishhh.net
# Comma-separated role keys from src/types/roles.ts (e.g. "BUSINESS_EXCELLENCE,SYSTEM_ADMIN")
DEV_SESSION_ROLE_KEYS=BUSINESS_EXCELLENCE
# Optional: restrict the mock user to a single brand / department
DEV_SESSION_BRAND_ID=
DEV_SESSION_DEPARTMENT_ID=
